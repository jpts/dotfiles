[ -z "$ZPROF" ] || zmodload zsh/zprof

setopt cshnullglob

# Precompile plugins
# https://github.com/romkatv/zsh-bench/blob/master/configs/diy%2B%2B/skel/.zshrc
function zcompile-many() {
  local f
  for f; do
      if [[ ! -e "$f.zwc" || "$f" -nt "$f.zwc" ]]; then
          #echo "Compiling $f"
          zcompile -R -- "$f".zwc "$f"
      fi
  done
}

function zcompile-antidote-plugins() {
  setopt cshnullglob
  setopt extendedglob
  IFS=$'\n' local LIST=($(antidote list | awk '{print $2}'))
  for DIR in $LIST[@]; do
    if [[ -n $DIR/**/*.zsh(#qN) ]]; then
      zcompile-many $DIR/**/*.zsh
    fi
  done
  unset IFS
}

export DOTFILES="$HOME/.dotfiles"
ZSH="$HOME/.zsh/config"
export ZSH_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
export ANTIDOTECACHE="${XDG_CACHE_HOME:-$HOME/.cache}/antidote"
export ANTIDOTEDIR="$ZSH_CACHE_DIR/antidote"

# Plugin Options
# https://github.com/zsh-users/zsh-autosuggestions#disabling-automatic-widget-re-binding
# _zsh_autosuggest_bind_widgets
ZSH_AUTOSUGGEST_MANUAL_REBIND=1

# ZSH Defaults
for file in $ZSH/init/*.zsh; do
    source "$file"
done

# Load Antidote
fpath+=("$ANTIDOTEDIR")
autoload -Uz "$ANTIDOTEDIR/antidote"

if [[ ! -s "$ZSH_CACHE_DIR/plugins_bundle.zsh" || "$ZSH/plugins" -nt "$ZSH_CACHE_DIR/plugins_bundle.zsh" ]]; then
    echo "Rebuilding ZSH plugin list..."
    mkdir -p "$ZSH_CACHE_DIR"
    antidote bundle < "$ZSH/plugins" > "$ZSH_CACHE_DIR/plugins_bundle.zsh"
    zcompile-antidote-plugins
fi
export GITSTATUS_AUTO_INSTALL=0
source $ZSH_CACHE_DIR/plugins_bundle.zsh

for file in $HOME/.zsh/aliases/*.{zsh,sh}; do
    source "$file"
done

if [ -f $DOTFILES/aliases_local ]; then
  source $DOTFILES/aliases_local
fi

# compinit magic
# the right order is
#  1. generate _files
#  2. compinit ++ if new files
#  3. bashcompinit
#  4. extra compdefs

for file in $ZSH/precompinit/*.zsh; do
    source "$file"
done

source $ZSH/compinit.zsh

for file in $ZSH/postcompinit/*.zsh; do
    source "$file"
done


[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
[ -z "$ZPROF" ] || zprof
